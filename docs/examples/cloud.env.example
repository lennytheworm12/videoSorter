# Add these to your local .env when setting up the hosted query stack.
# Use the Supabase Session Pooler URI here if your machine or Render service is
# on an IPv4-only network.

SUPABASE_DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<pooler-host>:5432/postgres
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<supabase-anon-key>
VECTOR_BACKEND=supabase
REQUIRE_AUTH=false
DAILY_QUERY_LIMIT=100
BACKEND_LABEL=Render fallback backend
BACKEND_QUALITY=fallback
